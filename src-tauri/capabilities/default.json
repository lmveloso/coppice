{
  "$schema": "https://raw.githubusercontent.com/nicotsx/tauri/v2/crates/tauri-utils/schema.json",
  "identifier": "default",
  "description": "Default capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:allow-set-decorations",
    "shell:allow-open",
    "dialog:default"
  ]
}
